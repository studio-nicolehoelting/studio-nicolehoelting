---
import {
    Swiper,
    SwiperButtonNext,
    SwiperButtonPrev,
    SwiperPagination,
    SwiperSlide,
    SwiperWrapper,
    type AstroSwiperOptions,
} from "astro-swiper";
import { getCollection } from "astro:content";

const reviews = await getCollection("rezensionen").then((reviews) =>
    reviews.sort((a, b) => (a.data.datum < b.data.datum ? 1 : -1)),
);

const swiperOptions: AstroSwiperOptions = {
    spaceBetween: 30,
    centeredSlides: true,
    autoplay: {
        delay: 10000,
        disableOnInteraction: true,
    },
    rewind: true,
    grabCursor: true,
    pagination: reviews.length > 1 && {
        el: ".swiper-pagination",
        clickable: true,
        dynamicBullets: true,
    },
    navigation: reviews.length > 1 && {
        nextEl: ".swiper-button-next",
        prevEl: ".swiper-button-prev",
    },
};
---

<Swiper class="reviews-swiper" options={swiperOptions}>
    <SwiperWrapper>
        {
            reviews.map(async (review) => {
                const { Content } = await review.render();
                return (
                    <SwiperSlide>
                        <blockquote>
                            <div class="content">
                                <Content />
                            </div>
                            <p class="name">- {review.data.name}</p>
                        </blockquote>
                    </SwiperSlide>
                );
            })
        }
    </SwiperWrapper>
    {
        reviews.length > 1 && (
            <>
                <SwiperButtonPrev />
                <SwiperButtonNext />
                <SwiperPagination />
            </>
        )
    }
</Swiper>

<style lang="scss">
    .reviews-swiper {
        width: 100%;
        height: 100%;
        border: 2px solid var(--logo-color);

        .swiper-button-next,
        .swiper-button-prev {
            display: none;

            @media only screen and (min-width: $breakpoint-s) {
                display: block;
                color: var(--logo-color);
            }
        }

        .swiper-pagination :global(.swiper-pagination-bullet-active) {
            background-color: var(--logo-color);
        }

        .swiper-slide {
            padding-block: 1em;
            text-align: center;
            display: flex;
            justify-content: center;
            align-items: center;
            user-select: none;

            @media only screen and (min-width: $breakpoint-s) {
                padding-inline: 2em;
            }

            blockquote {
                font-size: 0.75em;
                display: flex;
                flex-direction: column;
                justify-content: space-between;

                .name {
                    font-style: italic;
                    margin-top: 0.5em;
                }
            }
        }

        .swiper-slide img {
            display: block;
            object-fit: cover;

            :root[data-theme="dark"] & {
                filter: brightness(0.6);
            }
        }
    }
</style>
