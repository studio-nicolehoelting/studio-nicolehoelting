---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BasicLayout from "@layouts/BasicLayout.astro";
import {
    Swiper,
    SwiperButtonNext,
    SwiperButtonPrev,
    SwiperPagination,
    SwiperSlide,
    SwiperWrapper,
} from "astro-swiper";
import type { SwiperOptions } from "swiper/types";

const artworks = await getCollection("artworks").then((projects) =>
    projects.sort((a, b) => b.data.priorität - a.data.priorität),
);

const swiperOptions: SwiperOptions = {
    spaceBetween: 10,
    centeredSlides: true,
    rewind: true,
    grabCursor: true,
    pagination: {
        el: ".swiper-pagination",
        clickable: true,
        dynamicBullets: true,
    },
    navigation: {
        nextEl: ".swiper-button-next",
        prevEl: ".swiper-button-prev",
    },
};
---

<BasicLayout title="artworks - Studio NH" hasUpButton>
    <main class="artworks-grid">
        {
            artworks.map(async (artwork) => {
                const { Content } = await artwork.render();
                return (
                    <div class="artwork">
                        {artwork.data.bilder.length == 1 ? (
                            <Image
                                src={artwork.data.bilder[0]}
                                alt={artwork.data.titel}
                                quality={"mid"}
                            />
                        ) : (
                            <Swiper
                                class="artwork-swiper"
                                options={swiperOptions}
                            >
                                <SwiperWrapper>
                                    {artwork.data.bilder.map((bild, index) => (
                                        <SwiperSlide>
                                            <Image
                                                src={bild}
                                                alt={`${artwork.data.titel} - Bild ${index + 1}`}
                                                quality={"mid"}
                                            />
                                        </SwiperSlide>
                                    ))}
                                </SwiperWrapper>
                                <SwiperButtonNext />
                                <SwiperButtonPrev />
                                <SwiperPagination />
                            </Swiper>
                        )}

                        <h2>{artwork.data.titel}</h2>
                        <span>
                            <Content />
                        </span>
                    </div>
                );
            })
        }
    </main>
</BasicLayout>

<style lang="scss">
    .artworks-grid {
        margin: 0.5em;
        display: grid;
        gap: 0.5em;
        grid-template-columns: auto;

        @media only screen and (min-width: $breakpoint-xs) {
            margin: 2em;
        }

        @media only screen and (min-width: $breakpoint-l) {
            margin-inline: auto;
            max-width: 80em;
        }

        h1 {
            margin-bottom: 0.5em;
        }

        @media only screen and (min-width: $breakpoint-s) {
            grid-template-columns: repeat(2, 1fr);
            gap: 1em;
        }

        @media only screen and (min-width: $breakpoint-l) {
            gap: 3em;
        }

        .artwork {
            min-width: 0;
            width: 100%;
            padding: 1.5em;
            padding-bottom: 1em;
            border: 2px solid var(--logo-color);
            text-decoration: none;
            color: var(--logo-text-color);

            transition: box-shadow 0.2s;

            img {
                width: 100%;
                height: auto;
                aspect-ratio: 1;
                object-fit: contain;
            }

            .artwork-swiper {
                width: 100%;
                height: auto;
                aspect-ratio: 1;
                overflow: clip;

                .swiper-wrapper {
                    width: 100%;
                    height: 100%;
                    padding-bottom: 15px;

                    .swiper-slide {
                        width: 100%;
                        height: 100%;
                    }
                }

                .swiper-button-next,
                .swiper-button-prev {
                    display: none;

                    @media only screen and (min-width: $breakpoint-s) {
                        display: block;
                        color: var(--logo-color);
                        filter: drop-shadow(0 0 4px black)
                            drop-shadow(0 0 8px black);
                    }
                }

                .swiper-pagination {
                    position: relative;
                    :global(.swiper-pagination-bullet-active) {
                        background-color: var(--logo-color);
                    }
                }
            }

            h2 {
                text-align: center;
                margin-top: 0.25em;
                min-height: 3em;
                align-content: center;

                @media only screen and (min-width: $breakpoint-xs) and (max-width: $breakpoint-s) {
                    font-size: 2em;
                }

                @media only screen and (min-width: $breakpoint-s) {
                    font-size: 2.5em;
                }
            }

            span {
                text-align: center;
            }
        }
    }
</style>
